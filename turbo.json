{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NOTION_API_KEY", "NOTION_DATABASE_ID", "REVALIDATE_SECRET"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
